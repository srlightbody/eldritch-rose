# Eldritch Rose@@name_suffix@@ - k9s skin
# place in ~/.config/k9s/skins/eldritch-rose.yaml, then set in config.yaml:
#   k9s:
#     ui:
#       skin: eldritch-rose

k9s:
  body:
    fgColor: "#@@text@@"
    bgColor: "#@@base@@"
    logoColor: "#@@aether@@"
  prompt:
    fgColor: "#@@text@@"
    bgColor: "#@@base@@"
    suggestColor: "#@@umbra@@"
  info:
    fgColor: "#@@aether@@"
    sectionColor: "#@@text@@"
  dialog:
    fgColor: "#@@text@@"
    bgColor: "#@@base@@"
    buttonFgColor: "#@@base@@"
    buttonBgColor: "#@@aether@@"
    buttonFocusFgColor: "#@@base@@"
    buttonFocusBgColor: "#@@blight@@"
    labelFgColor: "#@@witchfire@@"
    fieldFgColor: "#@@text@@"
  frame:
    border:
      fgColor: "#@@border@@"
      focusColor: "#@@siren@@"
    menu:
      fgColor: "#@@text@@"
      keyColor: "#@@umbra@@"
      numKeyColor: "#@@umbra@@"
    crumbs:
      fgColor: "#@@base@@"
      bgColor: "#@@hl_med@@"
      activeColor: "#@@aether@@"
    status:
      newColor: "#@@aether@@"
      modifyColor: "#@@rift@@"
      addColor: "#@@blight@@"
      errorColor: "#@@ichor@@"
      highlightColor: "#@@witchfire@@"
      killColor: "#@@umbra@@"
      completedColor: "#@@ash@@"
    title:
      fgColor: "#@@text@@"
      bgColor: "#@@base@@"
      highlightColor: "#@@witchfire@@"
      counterColor: "#@@umbra@@"
      filterColor: "#@@aether@@"
  views:
    charts:
      bgColor: "#@@base@@"
      defaultDialColors:
        - "#@@aether@@"
        - "#@@ichor@@"
      defaultChartColors:
        - "#@@aether@@"
        - "#@@ichor@@"
    table:
      fgColor: "#@@text@@"
      bgColor: "#@@base@@"
      cursorFgColor: "#@@base@@"
      cursorBgColor: "#@@border@@"
      header:
        fgColor: "#@@text@@"
        bgColor: "#@@base@@"
        sorterColor: "#@@blight@@"
    xray:
      fgColor: "#@@text@@"
      bgColor: "#@@base@@"
      cursorColor: "#@@border@@"
      graphicColor: "#@@aether@@"
    yaml:
      keyColor: "#@@rift@@"
      colonColor: "#@@shroud@@"
      valueColor: "#@@text@@"
    logs:
      fgColor: "#@@text@@"
      bgColor: "#@@base@@"
      indicator:
        fgColor: "#@@aether@@"
        bgColor: "#@@base@@"
