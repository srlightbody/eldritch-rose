# Eldritch Rose@@name_suffix@@ - wezterm
# place in ~/.config/wezterm/colors/, then: config.color_scheme = "Eldritch Rose@@name_suffix@@"

[metadata]
name = "Eldritch Rose@@name_suffix@@"
author = "Sam Lightbody"

[colors]
foreground = "#@@text@@"
background = "#@@base@@"
cursor_bg = "#@@blight@@"
cursor_fg = "#@@base@@"
cursor_border = "#@@blight@@"
selection_fg = "#@@b_white7@@"
selection_bg = "#@@hl_med@@"
ansi = ["#@@border@@", "#@@ichor@@", "#@@blight@@", "#@@witchfire@@", "#@@rift@@", "#@@umbra@@", "#@@aether@@", "#@@b_white7@@"]
brights = ["#@@ash@@", "#@@b_red@@", "#@@b_green@@", "#@@b_yellow@@", "#@@b_blue@@", "#@@b_magenta@@", "#@@b_cyan@@", "#@@text@@"]
