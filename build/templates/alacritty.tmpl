# Eldritch Rose@@name_suffix@@ - alacritty (0.13+)
# rose-pine backgrounds, eldritch accents

[colors.primary]
background = "#@@base@@"
foreground = "#@@text@@"

[colors.cursor]
text   = "#@@base@@"
cursor = "#@@blight@@"

[colors.selection]
text       = "#@@b_white7@@"
background  = "#@@hl_med@@"

[colors.normal]
black   = "#@@border@@"
red     = "#@@ichor@@"
green   = "#@@blight@@"
yellow  = "#@@witchfire@@"
blue    = "#@@rift@@"
magenta = "#@@umbra@@"
cyan    = "#@@aether@@"
white   = "#@@b_white7@@"

[colors.bright]
black   = "#@@ash@@"
red     = "#@@b_red@@"
green   = "#@@b_green@@"
yellow  = "#@@b_yellow@@"
blue    = "#@@b_blue@@"
magenta = "#@@b_magenta@@"
cyan    = "#@@b_cyan@@"
white   = "#@@text@@"
