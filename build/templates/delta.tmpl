# Eldritch Rose@@name_suffix@@ - delta
# include from ~/.gitconfig:
#   [include]
#       path = ~/.config/delta/eldritch-rose.gitconfig
# syntax-theme expects bat's "Eldritch Rose@@name_suffix@@" tmTheme on the bat themes path.

[delta]
	syntax-theme = Eldritch Rose@@name_suffix@@
	line-numbers = true

	minus-style = syntax "#@@d_minus@@"
	minus-emph-style = syntax "#@@d_minus_emph@@"
	plus-style = syntax "#@@d_plus@@"
	plus-emph-style = syntax "#@@d_plus_emph@@"

	line-numbers-minus-style = "#@@ichor@@"
	line-numbers-plus-style = "#@@blight@@"
	line-numbers-zero-style = "#@@ash@@"
	line-numbers-left-style = "#@@border@@"
	line-numbers-right-style = "#@@border@@"

	file-style = "#@@aether@@" bold
	file-decoration-style = "#@@border@@" ul
	hunk-header-style = "#@@umbra@@" bold
	hunk-header-decoration-style = "#@@border@@" box

	zero-style = syntax
	whitespace-error-style = "#@@ichor@@" reverse
