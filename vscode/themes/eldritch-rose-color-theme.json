{
	"name": "Eldritch Rose",
	"type": "dark",
	"semanticHighlighting": true,
	"colors": {
		"focusBorder": "#3e4750",
		"foreground": "#ebfafa",
		"selection.background": "#3e4750",
		"descriptionForeground": "#908caa",
		"errorForeground": "#eb6f92",
		"icon.foreground": "#908caa",

		"editor.background": "#08161a",
		"editor.foreground": "#ebfafa",
		"editorLineNumber.foreground": "#6e6a86",
		"editorLineNumber.activeForeground": "#ebfafa",
		"editor.selectionBackground": "#3e4750",
		"editor.selectionHighlightBackground": "#202e34",
		"editor.wordHighlightBackground": "#3e4750",
		"editor.wordHighlightStrongBackground": "#505a64",
		"editor.findMatchBackground": "#e8be2244",
		"editor.findMatchHighlightBackground": "#e8be2222",
		"editor.lineHighlightBackground": "#0d1f25",
		"editorCursor.foreground": "#37f499",
		"editorWhitespace.foreground": "#202e34",
		"editorIndentGuide.background1": "#202e34",
		"editorIndentGuide.activeBackground1": "#3e4750",
		"editorBracketMatch.background": "#3e4750",
		"editorBracketMatch.border": "#00000000",

		"editorGutter.addedBackground": "#04d1f9",
		"editorGutter.modifiedBackground": "#f48fc9",
		"editorGutter.deletedBackground": "#eb6f92",

		"editorError.foreground": "#eb6f92",
		"editorWarning.foreground": "#e8be22",
		"editorInfo.foreground": "#04d1f9",
		"editorHint.foreground": "#a48cf2",

		"diffEditor.insertedTextBackground": "#04d1f922",
		"diffEditor.removedTextBackground": "#eb6f9222",

		"editorWidget.background": "#0d1f25",
		"editorWidget.border": "#3e4750",
		"editorSuggestWidget.background": "#0d1f25",
		"editorSuggestWidget.selectedBackground": "#202e34",
		"editorSuggestWidget.highlightForeground": "#04d1f9",
		"editorHoverWidget.background": "#0d1f25",
		"editorHoverWidget.border": "#3e4750",

		"input.background": "#0d1f25",
		"input.foreground": "#ebfafa",
		"input.border": "#3e4750",
		"input.placeholderForeground": "#6e6a86",
		"inputOption.activeBorder": "#04d1f9",
		"dropdown.background": "#0d1f25",
		"dropdown.border": "#3e4750",

		"badge.background": "#04d1f9",
		"badge.foreground": "#08161a",
		"progressBar.background": "#04d1f9",

		"button.background": "#04d1f9",
		"button.foreground": "#08161a",
		"button.hoverBackground": "#66e4fd",
		"button.secondaryBackground": "#202e34",
		"button.secondaryForeground": "#ebfafa",

		"list.activeSelectionBackground": "#202e34",
		"list.activeSelectionForeground": "#ebfafa",
		"list.inactiveSelectionBackground": "#0d1f25",
		"list.hoverBackground": "#0d1f25",
		"list.highlightForeground": "#04d1f9",
		"list.focusBackground": "#202e34",

		"scrollbarSlider.background": "#3e475088",
		"scrollbarSlider.hoverBackground": "#505a64aa",
		"scrollbarSlider.activeBackground": "#505a64",

		"sideBar.background": "#08161a",
		"sideBar.foreground": "#ebfafa",
		"sideBarTitle.foreground": "#908caa",
		"sideBarSectionHeader.background": "#0d1f25",
		"sideBarSectionHeader.foreground": "#ebfafa",

		"activityBar.background": "#08161a",
		"activityBar.foreground": "#ebfafa",
		"activityBar.inactiveForeground": "#6e6a86",
		"activityBarBadge.background": "#04d1f9",
		"activityBarBadge.foreground": "#08161a",

		"statusBar.background": "#0d1f25",
		"statusBar.foreground": "#ebfafa",
		"statusBar.noFolderBackground": "#0d1f25",
		"statusBar.debuggingBackground": "#a48cf2",
		"statusBar.debuggingForeground": "#08161a",

		"titleBar.activeBackground": "#08161a",
		"titleBar.activeForeground": "#ebfafa",
		"titleBar.inactiveBackground": "#08161a",
		"titleBar.inactiveForeground": "#6e6a86",

		"tab.activeBackground": "#08161a",
		"tab.activeForeground": "#ebfafa",
		"tab.inactiveBackground": "#0d1f25",
		"tab.inactiveForeground": "#6e6a86",
		"tab.activeBorder": "#04d1f9",
		"tab.border": "#08161a",

		"panel.background": "#08161a",
		"panel.border": "#3e4750",
		"panelTitle.activeForeground": "#ebfafa",
		"panelTitle.inactiveForeground": "#6e6a86",

		"breadcrumb.foreground": "#6e6a86",
		"breadcrumb.focusForeground": "#ebfafa",

		"gitDecoration.addedResourceForeground": "#37f499",
		"gitDecoration.modifiedResourceForeground": "#f48fc9",
		"gitDecoration.deletedResourceForeground": "#eb6f92",
		"gitDecoration.untrackedResourceForeground": "#908caa",
		"gitDecoration.ignoredResourceForeground": "#6e6a86",

		"terminal.foreground": "#ebfafa",
		"terminal.ansiBlack": "#202e34",
		"terminal.ansiBrightBlack": "#6e6a86",
		"terminal.ansiRed": "#eb6f92",
		"terminal.ansiBrightRed": "#f9515d",
		"terminal.ansiGreen": "#37f499",
		"terminal.ansiBrightGreen": "#69f8b3",
		"terminal.ansiYellow": "#e8be22",
		"terminal.ansiBrightYellow": "#f1fc79",
		"terminal.ansiBlue": "#4d8bff",
		"terminal.ansiBrightBlue": "#7aa6ff",
		"terminal.ansiMagenta": "#a48cf2",
		"terminal.ansiBrightMagenta": "#fd92ce",
		"terminal.ansiCyan": "#04d1f9",
		"terminal.ansiBrightCyan": "#66e4fd",
		"terminal.ansiWhite": "#e0def4",
		"terminal.ansiBrightWhite": "#ebfafa"
	},
	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": { "foreground": "#908caa", "fontStyle": "italic" }
		},
		{
			"scope": ["string", "string.quoted", "constant.other.symbol"],
			"settings": { "foreground": "#e8be22" }
		},
		{
			"scope": ["constant.numeric", "constant.other"],
			"settings": { "foreground": "#e8be22" }
		},
		{
			"scope": ["constant.language", "constant.language.boolean"],
			"settings": { "foreground": "#f48fc9" }
		},
		{
			"scope": ["variable", "variable.other", "meta.definition.variable.name"],
			"settings": { "foreground": "#ebfafa" }
		},
		{
			"scope": ["variable.parameter", "meta.function.parameters"],
			"settings": { "foreground": "#a48cf2", "fontStyle": "italic" }
		},
		{
			"scope": ["variable.other.member", "support.variable.property", "meta.object-literal.key"],
			"settings": { "foreground": "#04d1f9" }
		},
		{
			"scope": ["keyword", "keyword.control", "keyword.other", "modifier"],
			"settings": { "foreground": "#4d8bff" }
		},
		{
			"scope": ["keyword.operator", "punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"],
			"settings": { "foreground": "#908caa" }
		},
		{
			"scope": ["storage", "storage.type", "storage.modifier"],
			"settings": { "foreground": "#04d1f9" }
		},
		{
			"scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
			"settings": { "foreground": "#f48fc9" }
		},
		{
			"scope": ["entity.name.type", "entity.name.class", "entity.name.namespace", "support.type", "support.class"],
			"settings": { "foreground": "#04d1f9" }
		},
		{
			"scope": ["entity.name.tag", "support.constant.handlebars"],
			"settings": { "foreground": "#04d1f9" }
		},
		{
			"scope": ["entity.other.attribute-name", "meta.attribute"],
			"settings": { "foreground": "#a48cf2" }
		},
		{
			"scope": ["support.constant", "support.type.property-name"],
			"settings": { "foreground": "#04d1f9" }
		},
		{
			"scope": ["markup.heading", "markup.heading entity.name"],
			"settings": { "foreground": "#04d1f9", "fontStyle": "bold" }
		},
		{
			"scope": ["markup.bold"],
			"settings": { "foreground": "#e8be22", "fontStyle": "bold" }
		},
		{
			"scope": ["markup.italic"],
			"settings": { "fontStyle": "italic" }
		},
		{
			"scope": ["markup.inserted"],
			"settings": { "foreground": "#37f499" }
		},
		{
			"scope": ["markup.deleted"],
			"settings": { "foreground": "#eb6f92" }
		},
		{
			"scope": ["markup.changed"],
			"settings": { "foreground": "#f48fc9" }
		},
		{
			"scope": ["markup.underline.link", "string.other.link"],
			"settings": { "foreground": "#a48cf2", "fontStyle": "underline" }
		},
		{
			"scope": ["invalid", "invalid.illegal"],
			"settings": { "foreground": "#eb6f92" }
		}
	],
	"semanticTokenColors": {
		"parameter": "#a48cf2",
		"property": "#04d1f9",
		"variable": "#ebfafa",
		"function": "#f48fc9",
		"method": "#f48fc9",
		"class": "#04d1f9",
		"type": "#04d1f9",
		"enum": "#04d1f9",
		"interface": "#04d1f9",
		"keyword": "#4d8bff",
		"namespace": "#ebfafa"
	}
}
